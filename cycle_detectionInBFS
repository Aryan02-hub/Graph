#include<iostream>
#include<vector>
#include<list>
#include<queue>
using namespace std;

class Graph{
    int V;
    list<int> *l;
public:
    Graph(int v){
        this->V=v;
        l=new list<int>[v];
    }

    void addEdges(int u, int v){
        l[u].push_back(v);
        l[v].push_back(u);
    }

    bool isCycledetectionBFS(int src, vector<bool>&vis){
        queue<pair<int, int>>q;
        q.push({src, -1});
        vis[src]=true;
        while(!q.empty()){
            int node=q.front().first;
            int parent=q.front().second;
            q.pop();
            for(auto nbr:l[node]){
                if(!vis[nbr]){
                    vis[nbr]=true;
                    q.push({nbr, node});
                }
                else if(nbr!=parent){
                    return true;
                }
            }
        }
        return false;
    }

    bool bfs(){
        vector<bool>vis(V, false);
        for(int i=0; i<V; i++){
            if(!vis[i]){
                if(isCycledetectionBFS(i, vis)){
                    return true;
                }
            }
        }
        return false;
    }
};

int main(){
    Graph g(5);
    g.addEdges(0, 1);
    g.addEdges(1, 2);
    g.addEdges(0, 2);
    g.addEdges(0, 3);
    g.addEdges(3, 4);
    //g.printEdges();
    if(g.bfs()){
        cout<<"Cycle is present in the graph"<<endl;
    }
    else{
        cout<<"Cycle is not present in the graph"<<endl;    
    }
    return 0;
}
