#include<iostream>
#include<vector>
#include<list>
#include<queue>
#include <climits>
using namespace std;

class Edge{
public: 
    int V;
    int u;
    int wt;

    Edge(int u, int V, int wt){
        this -> V = V;
        this -> wt = wt;
        this -> u = u;
    }
};

void bellManFord(int src, vector<Edge>&edges, int V){
    vector<int>dist(V, 1e9);
    dist[src]=0;

    for(int i=0; i<V-1; i++){
        for(Edge e : edges){
            if(dist[e.u]!=1e9 && dist[e.V]> dist[e.u]+e.wt){
                dist[e.V]=dist[e.u]+e.wt;
            }
        }
    }

    for(Edge e : edges){
        if(dist[e.u]!=1e9 && dist[e.V]> dist[e.u]+e.wt){
            dist[e.V]=dist[e.u]+e.wt;
        }    
    }

    for(int i=0; i<V; i++){
        cout<<dist[i]<<" ";
    }
    cout<<endl;
}

int main(){
    int v=6;
    vector<Edge>edges;
    edges.push_back(Edge(0,2,4));
    edges.push_back(Edge(0,1,2));

    edges.push_back(Edge(1,2,1));
    edges.push_back(Edge(1,3,7));

    edges.push_back(Edge(2,4,-3));

    edges.push_back(Edge(3,5,-1));

    edges.push_back(Edge(4,3,2));
    edges.push_back(Edge(4,5,-5));

    bellManFord(0, edges, v);         
    return 0;
}
